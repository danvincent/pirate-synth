[Unit]
Description=Pirate Synth first boot installer
After=network-online.target
Wants=network-online.target
ConditionPathExists=!/var/lib/pirate-synth/firstboot.done

[Service]
Type=oneshot
ExecStart=/bin/bash /boot/firmware/pirate-synth/install-gpi.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target